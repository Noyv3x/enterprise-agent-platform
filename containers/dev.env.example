UBITECH_COMPOSE_PROJECT=ubitech-agent-dev
UBITECH_DATA_ROOT=/tmp/ubitech-agent-dev
UBITECH_SECRETS_DIR=/tmp/ubitech-agent-dev/manager/secrets
UBITECH_MANAGER_CONTROL_DIR=/tmp/ubitech-agent-dev/manager/control
UBITECH_PLATFORM_BIND=127.0.0.1:18080
UBITECH_PUBLIC_BASE_URL=http://127.0.0.1:18080
UBITECH_CORE_NETWORK=ubitech-agent-dev_core
UBITECH_UID=1000
UBITECH_GID=1000
UBITECH_PLATFORM_IMAGE=ubitech-agent/platform:dev
UBITECH_AGENT_RUNTIME_IMAGE=ubitech-agent/agent-runtime:dev
UBITECH_CAMOFOX_IMAGE=ubitech-agent/camofox:dev
