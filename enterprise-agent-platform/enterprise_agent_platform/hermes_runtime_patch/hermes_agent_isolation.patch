+def _memory_scope_dir_name(scope_key: str) -> str:
+    """Return a filesystem-safe, stable directory name for an agent memory scope."""
+    raw = str(scope_key or "").strip()
+    digest = hashlib.sha256(raw.encode("utf-8")).hexdigest()[:12]
+    safe = re.sub(r"[^A-Za-z0-9_.-]+", "-", raw).strip(".-") or "agent"
+    if len(safe) > 80:
+        safe = safe[:80].rstrip(".-") or "agent"
+    return f"{safe}-{digest}"
+
+
+def get_memory_dir(scope_key: str | None = None) -> Path:
+    """Return the profile-scoped memories directory.
+
+    Without a scope key this preserves the historical profile-level memory
+    files. Gateway/API agents pass a stable session key so each enterprise
+    agent gets its own MEMORY.md and USER.md under ``memories/agents/``.
+    """
+    base = get_hermes_home() / "memories"
+    clean_scope = str(scope_key or "").strip()
+    if clean_scope:
+        return base / "agents" / _memory_scope_dir_name(clean_scope)
+    return base
 
