{
  "name": "@ubitech/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Platform-owned ubitech agent runtime based on pi agent core",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "import-legacy-sessions": "node dist/src/legacy-session-importer.js",
    "start": "node dist/src/server.js",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.6",
    "@earendil-works/pi-ai": "0.80.6"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "typescript": "5.9.3"
  }
}
